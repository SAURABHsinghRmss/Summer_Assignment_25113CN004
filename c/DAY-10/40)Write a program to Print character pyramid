#include <stdio.h>
int main(){
    int h,i,j,k,l;
    char m;
    printf("Enter the height of the pyramid: ");
    scanf("%d",&h);
    for(i=1;i<=h;i++){
        for(j=h;j>i;j--){
            printf(" ");
        }
        for(k=0;k<i;k++){
            m='A'+k;
            printf("%c",m);
        }
        for(l=1;l<=i-1;l++){
            printf("%c",m-l);
        }
        printf("\n");
    }
}