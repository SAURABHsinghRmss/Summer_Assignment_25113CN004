#include <stdio.h>
int main(){
    int h,i,j,k,l;
    printf("Enter the height of the pyramid: ");
    scanf("%d",&h);
    for(i=1;i<=h;i++){
        for(j=h;j>i;j--){
            printf(" ");
        }
        for(k=1;k<=i;k++){
            printf("%d",k);
        }
        for(l=i-1;l>=1;l--){
            printf("%d",l);
        }
        printf("\n");
    }
}