#include <stdio.h>
int main(){
    int h,i,j,k,x;
    printf("Enter the height of the pyramid: ");
    scanf("%d",&h);
    x=h-1;
    for(i=h;i>=1;i--){
        for(j=h-i;j>0;j--){
            printf(" ");
        }
        for(k=i+x;k>0;k--){
            printf("*");
        }
        x--;
        printf("\n");
    }
}