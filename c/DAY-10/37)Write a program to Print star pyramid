#include <stdio.h>
int main(){
    int h,i,j,k,x=0;
    printf("Enter the height of the pyramid: ");
    scanf("%d",&h);
    for(i=1;i<=h;i++){
        for(j=h-i;j>0;j--){
            printf(" ");
        }
        for(k=i+x;k>0;k--){
            printf("*");
        }
        x++;
        printf("\n");
    }
}