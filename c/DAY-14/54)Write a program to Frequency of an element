#include <stdio.h>
#include <stdlib.h>
int* INarray(int s){
    int *arr=(int*)malloc(s*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",s);
    for(int i=0 ;i<s ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}
void frequency(int* ptr , int s){
    unsigned long int item, count=0;
    printf("Enter number to find it's frequency = ");
    if(scanf("%lu",&item)!=1){
        printf("Invalid input. \n");
        return;
    }
    printf("REQUIRED output : \n");
    for(int i=0 ;i<s ;i++){
        if((*(ptr+i))==item){
            count++;
        }
    }
    if(count==0){
        printf("element %lu is not found \n",item);
    }
    else{
        printf("frequency of element %lu is found %lu times \n",item,count);
    }
}

int main(){
    int n;
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n);
    if(n<=1){
        printf("Invalid size. \n");
        return 1;
    }

    int *ptr = INarray(n);

    frequency(ptr , n);

    return 0;
}