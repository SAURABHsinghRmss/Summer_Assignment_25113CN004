#include <stdio.h>
#include <stdlib.h>
int* INarray(int s){
    int *arr=(int*)malloc(s*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",s);
    for(int i=0 ;i<s ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}
void Secondlarge(int* ptr , int s){
    unsigned long int x, y;
    x = y = *ptr;
    printf("REQUIRED output : \n");
    for(int i=1 ;i<s ;i++){
        if((*(ptr+i))>x){
            y=x;
            x=*(ptr+i);
        }
    }
    if(x==y){
        printf("Second largest element not found.");
    }
    else{
        printf("Second largest element is %lu \n",y);
    }
}

int main(){
    int n;
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n);
    if(n<=1){
        printf("Invalid size. \n");
        return 1;
    }

    int *ptr = INarray(n);

    Secondlarge(ptr , n);

    return 0;
}