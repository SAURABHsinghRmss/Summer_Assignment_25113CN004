#include <stdio.h>
unsigned long long int fib(unsigned int n) {
    if (n == 0) return 0;
    if (n == 1) return 1;
    return fib(n-1) + fib(n-2);
}
int main() {
    unsigned int n;
    printf("Enter a non-negative integer: ");
    scanf("%u", &n);
    for (int i = 0; i < n; i++)
        printf("%d: %u\n", i+1, fib(i));
    return 0;
}