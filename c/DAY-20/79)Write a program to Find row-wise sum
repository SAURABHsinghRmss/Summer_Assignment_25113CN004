#include <stdio.h>
#include <stdlib.h>

int* INarray(int n, int m) {
    int *arr = (int*)malloc(n*m * sizeof(int));
    if(arr == NULL) {
        printf("Memory Allocation failed!!\n");
        exit(1);
    }
    printf("Enter elements of %dx%d matrix:\n", n, m);
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            printf("Element [%d][%d] = ", i+1, j+1);
            scanf("%d", &arr[i*m + j]);
        }
    }
    return arr;
}

void RowSum(int* arr, int n, int m) {
    for(int i = 0; i < n; i++) {
        int s = 0;
        for(int j = 0; j < m; j++) {
            s += arr[i*m + j];
        }
        printf("Sum of row %d = %d\n", i+1, s);
    }
}

int main() {
    int n, m;
    printf("FOR MATRIX :\n");
    printf("Enter number of rows = ");
    scanf("%d", &n);
    printf("Enter number of columns = ");
    scanf("%d", &m);

    if(n <= 0 || m <= 0) {
        printf("Invalid size.\n");
        return 1;
    }

    int *ptr = INarray(n, m);
    RowSum(ptr, n, m);

    free(ptr);
    return 0;
}
