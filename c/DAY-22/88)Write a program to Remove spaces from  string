#include <stdio.h>
#include <stdlib.h>

char* getString() {
    int size = 10, len = 0;
    char *str = (char*)malloc(size * sizeof(char));
    if(str == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }

    int ch;
    while((ch = getchar()) != '\n' && ch != EOF) {
        if(len >= size - 1) {
            size *= 2;
            str = (char*)realloc(str, size * sizeof(char));
            if(str == NULL) {
                printf("Memory reallocation failed!\n");
                exit(1);
            }
        }
        str[len++] = (char)ch;
    }
    str[len] = '\0';
    return str;
}

void removeSpaces(char *str) {
    int i, j = 0;
    for(i = 0; str[i] != '\0'; i++) {
        if(str[i] != ' ') {  
            str[j++] = str[i];
        }
    }
    str[j] = '\0'; 
}

int main() {
    printf("Enter a string: ");
    char *str = getString();

    removeSpaces(str);

    printf("String without spaces: %s\n", str);

    free(str);
    return 0;
}
