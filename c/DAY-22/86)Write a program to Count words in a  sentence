#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

char* getString() {
    int size = 50, len = 0;
    char *str = (char*)malloc(size * sizeof(char));
    if(str == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }

    int ch;
    while((ch = getchar()) != '\n' && ch != EOF) {
        if(len >= size - 1) {
            size *= 2;
            str = (char*)realloc(str, size * sizeof(char));
            if(str == NULL) {
                printf("Memory reallocation failed!\n");
                exit(1);
            }
        }
        str[len++] = (char)ch;
    }
    str[len] = '\0';
    return str;
}

int countWords(char *str) {
    int count = 0;
    int inWord = 0;  

    for(int i = 0; str[i] != '\0'; i++) {
        if(isalpha(str[i])) {   
            if(inWord == 0) {  
                count++;
                inWord = 1;
            }
        } else {
            inWord = 0; 
        }
    }
    return count;
}

int main() {
    printf("Enter a sentence: ");
    char *str = getString();

    int words = countWords(str);
    printf("Number of words in input string = %d\n", words);

    free(str);
    return 0;
}