#include <stdio.h>
#include <stdlib.h>

int* INarray( int n , int m) {
    int *ptr=(int*)malloc((n*m)*sizeof(int));
    if(ptr==NULL){
        printf("Memory Allocation failed!! \n");
        free(ptr);
        exit(1);
    }
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            printf("Element [%d][%d] = ", i+1, j+1);
            scanf("%d", &ptr[i * m + j]);
        }
    }
    return ptr;
}

int* ADDmat(int* ptr1 , int* ptr2 , int n , int m){
    int *ptr=(int*)malloc((n*m)*sizeof(int));
    if(ptr==NULL){
        printf("Memory Allocation failed!! \n");
        free(ptr);
        exit(1);
    }

    for(int i=0 ; i < n ; i++){
        for(int j=0 ; j < m ; j++){
            ptr[i * m +j] = (ptr1[i * m +j])+(ptr2[i * m +j]);
        }
    }
    return ptr;
}

void OUTarray(int* arr, int n , int m) {
    printf("Resultant array:\n");
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            printf("%d ", arr[i * m + j]);
        }
        printf("\n");
    }
}

int main() {
    int n, m;
    printf("Enter number of rows = ");
    scanf("%d", &n);
    printf("Enter number of columns = ");
    scanf("%d", &m);
    if(n <= 1 || m<= 1) {
        printf("Invalid size.\n");
        return 1;
    }
    printf("\n For first array : \n");
    int *ptr1 = INarray(n,m);
    printf("\n For Second array : \n");
    int *ptr2 = INarray(n,m);
    int *arr = ADDmat(ptr1,ptr2,n,m);
    OUTarray(arr, n , m);
    free(ptr1);
    free(ptr2);
    free(arr);
    return 0;
}