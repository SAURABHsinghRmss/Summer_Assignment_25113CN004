#include <stdio.h>
#include <stdlib.h>

int* INarray(int n) {
    int *arr = (int*)malloc(n*n * sizeof(int));
    if(arr == NULL) {
        printf("Memory Allocation failed!!\n");
        exit(1);
    }
    printf("Enter elements of %dx%d matrix:\n", n, n);
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            printf("Element [%d][%d] = ", i+1, j+1);
            scanf("%d", &arr[i*n + j]);
        }
    }
    return arr;
}

int diagonalSum(int* arr, int n) {
    int sum1 = 0 , sum2 = 0;
    for(int i = 0; i < n; i++) {
        sum1 += arr[i*n + i]; 
        sum2 += arr[i*n + (n-1-i)];     
    }
    printf("Primary diagonal sum = %d \n",sum1);
    printf("Secondary diagonal sum = %d \n",sum2);
    int sum = sum1 + sum2;
    if(n % 2 == 1) {
        sum -= arr[(n/2)*n + (n/2)];
    }
    return sum;
}

int main() {
    int n;
    printf("Enter size of square matrix = ");
    scanf("%d", &n);
    if(n <= 1) {
        printf("Invalid size.\n");
        return 1;
    }
    int *ptr = INarray(n);
    int sum = diagonalSum(ptr, n);
    printf("Diagonal sum of matrix = %d\n", sum);
    free(ptr);
    return 0;
}
