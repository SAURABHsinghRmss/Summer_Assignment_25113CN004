#include <stdio.h>
#include <stdlib.h>
int* INarray(int s){
    int *arr=(int*)malloc(s*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",s);
    for(int i=0 ;i<s ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}
void missELE(int* ptr , int s){
    int max=*ptr;
    int k=0;
    for(int i=1 ; i<s ; i++){
        if(*(ptr+i)>max){
            max=*(ptr+i);
        }
    }
    printf("Missing element in given array. \n");
    for(int i=1 ; i<=max ; i++){
        int j=0, f=0;
        while((j<s)&&(f==0)){
            if( *(ptr+j)==i ){
                f=1;
            }
            j++;
        }
        if(f==0){
            printf("%d \n",i);
            k++;
        }
    }
    if(k==0){
        printf("None found! \n");
    }
    return;
}

int main(){
    int n;
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n);
    if(n<=1){
        printf("Invalid size. \n");
        return 1;
    }

    int *ptr = INarray(n);

    missELE(ptr , n);

    free(ptr);
    return 0;
}