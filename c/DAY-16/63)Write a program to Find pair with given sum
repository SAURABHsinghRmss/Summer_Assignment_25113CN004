#include <stdio.h>
#include <stdlib.h>

int* INarray(int s) {
    int *arr = (int*)malloc(s * sizeof(int));
    if (arr == NULL) {
        printf("Memory allocation failed\n");
        exit(1);
    }
    printf("Enter %d integers:\n", s);
    for (int i = 0; i < s; i++) {
        printf("Element %d = ", i + 1);
        if (scanf("%d", &arr[i]) != 1) {
            printf("Invalid input.\n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}

void sumPAIR(int* ptr, int s) {
    int sum;
    printf("Enter the sum to find pairs for = ");
    if (scanf("%d", &sum) != 1) {
        printf("Invalid input.\n");
        return;
    }
    printf("Pairs with sum %d are:\n", sum);
    int found = 0, temp;
    for (int i = 0; i < s; i++) {
        temp=sum - *(ptr+i);
        for (int j = i + 1; j < s; j++) {
            if (*(ptr+j) == temp) {
                printf("(%d, %d)\n", *(ptr+i), *(ptr+j));
                found = 1;
            }
        }
    }
    if (!found) {
        printf("No pairs found with the given sum.\n");
    }
}

int main() {
    int n;
    printf("Enter number of elements in array = ");
    scanf("%d", &n);
    if (n <= 1) {
        printf("Invalid size.\n");
        return 1;
    }

    int *ptr = INarray(n);
    sumPAIR(ptr, n);
    free(ptr);

    return 0;
}