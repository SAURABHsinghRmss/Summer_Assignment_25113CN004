#include <stdio.h>
#include <stdlib.h>

int* INarray(int s) {
    int *arr = (int*)malloc(s * sizeof(int));
    if (arr == NULL) {
        printf("Memory allocation failed\n");
        exit(1);
    }
    printf("Enter %d integers:\n", s);
    for (int i = 0; i < s; i++) {
        printf("Element %d = ", i + 1);
        if (scanf("%d", &arr[i]) != 1) {
            printf("Invalid input.\n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}

void maxELEfreq(int* ptr, int s) {
    int maxFreq = 0;
    int maxElem = ptr[0];

    for (int i = 0; i < s; i++) {
        int count = 1;
        for (int j = i + 1; j < s; j++) {
            if (ptr[j] == ptr[i]) {
                count++;
            }
        }
        if (count > maxFreq) {
            maxFreq = count;
            maxElem = ptr[i];
        }
    }

    printf("Maximum frequency element = %d (appears %d times)\n", maxElem, maxFreq);
}

int main() {
    int n;
    printf("Enter number of elements in array = ");
    scanf("%d", &n);
    if (n <= 1) {
        printf("Invalid size.\n");
        return 1;
    }

    int *ptr = INarray(n);
    maxELEfreq(ptr, n);
    free(ptr);

    return 0;
}