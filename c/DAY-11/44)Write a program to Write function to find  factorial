#include <stdio.h>
unsigned int factorial(unsigned int num){
    unsigned int t=1;
    if(num<=1) return 1;
    else{
        while (num!=1){
            t*=num;
            num-=1;
        }
        return t;
    }
}
int main(){
    unsigned int n;
    printf("Enter number=");
    scanf("%u",&n);

    printf("Factoral of %u = %u",n,factorial(n));
    return 0;
}