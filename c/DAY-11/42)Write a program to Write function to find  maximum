#include <stdio.h>
#include <stdlib.h>
double* array(int s){
    double* a=(double*)malloc(s*sizeof(double));
    if(a==NULL){
        printf("Memory allocation failed!");
        exit(1);
    }
    for(int i=0;i<s;i++){
        printf("Enter the element %d: ",i+1);
        scanf("%lf",&a[i]);
    }
    return a;
}
double findMax(double* a,int s){
    double max=a[0];
    for(int i=1;i<s;i++){
        if(a[i]>max){
            max=a[i];
        }
    }
    return max;
}
int main(){
    int size;
    printf("Enter the numbers of numbers to be compared : ");
    scanf("%d",&size);
    double* arr=array(size);
    double max=findMax(arr,size);
    printf("The maximum element in the array is: %lf\n",max);
    free(arr);
    return 0;
}