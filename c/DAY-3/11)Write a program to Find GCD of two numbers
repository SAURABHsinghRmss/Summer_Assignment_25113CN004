#include <stdio.h>
int swap(unsigned int *a, unsigned int *b) {
    unsigned int temp = *a;
    *a = *b;
    *b = temp;
    return 0;
}
int gcd(unsigned int a, unsigned int b) {
    if (b == 0)
        return a;
    return gcd(b, a % b);
}
void main() {
    unsigned int num1, num2;
    printf("Enter first numbers: ");
    scanf("%u", &num1);
    printf("Enter second numbers: ");
    scanf("%u", &num2);
    if (num1 < num2) {
        swap(&num1, &num2);
    }
    printf("GCD of %u and %u is %u\n", num1, num2, gcd(num1, num2));
}