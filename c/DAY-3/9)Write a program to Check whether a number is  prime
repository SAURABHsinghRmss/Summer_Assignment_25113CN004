#include <stdio.h>
void main(){
    unsigned int num; 
    int i, flag = 0;
    printf("Enter a positive integer: ");
    scanf("%u", &num);
    for(i = 2; i <= num/2; ++i){
        if(num % i == 0){
            flag = 1;
            break;
        }
    }
    if(num <= 1){
        printf("%u is not a prime number.", num);
    }
    else{
        if (flag == 0)
            printf("%u is a prime number.", num);
        else
            printf("%u is not a prime number.", num);
    }
}