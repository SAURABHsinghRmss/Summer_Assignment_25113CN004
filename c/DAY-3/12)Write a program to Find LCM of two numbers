#include <stdio.h>
int main() {
    unsigned int num1, num2;
    printf("Enter first number: ");
    scanf("%u", &num1);
    printf("Enter second number: ");
    scanf("%u", &num2);
    
    if(num1==0 || num2==0) {
        printf("LCM of %u and %u is: 0\n", num1, num2);
        return 0;
    }
    unsigned int max = (num1>num2) ? num1 : num2;
    while (1) {
        if (max%num1==0 && max%num2==0) {
            printf("LCM of %u and %u is: %u\n", num1, num2, max);
            break;
        }
        max++;
    }
    return 0;
}