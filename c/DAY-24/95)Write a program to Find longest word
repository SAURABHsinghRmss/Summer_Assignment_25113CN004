#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

char* getString(int *len) {
    printf("Enter a sentence: ");
    int size = 50;
    *len = 0;
    char *str = (char*)malloc(size * sizeof(char));
    if(str == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }

    int ch;
    while((ch = getchar()) != '\n' && ch != EOF) {
        if(*len >= size - 1) {
            size *= 2;
            str = (char*)realloc(str, size * sizeof(char));
            if(str == NULL) {
                printf("Memory reallocation failed!\n");
                exit(1);
            }
        }
        str[(*len)++] = (char)ch;
    }
    str[*len] = '\0';
    return str;
}

void findLongestWord(char *str) {
    int maxLen = 0;
    char longest[100] = "";

    char *token = strtok(str, " ");  // split by spaces
    while(token != NULL) {
        int len = strlen(token);
        if(len > maxLen) {
            maxLen = len;
            strcpy(longest, token);
        }
        token = strtok(NULL, " ");
    }

    if(maxLen > 0)
        printf("Longest word: %s (length %d)\n", longest, maxLen);
    else
        printf("No words found.\n");
}

int main() {
    int len = 0;
    char *str = getString(&len);

    findLongestWord(str);

    free(str);
    return 0;
}
