#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char* getString(int *len) {
    printf("Enter a string: ");
    int size = 10;
    *len = 0; 
    char *str = (char*)malloc(size * sizeof(char));
    if(str == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }

    int ch;
    while((ch = getchar()) != '\n' && ch != EOF) {
        if(*len >= size - 1) {
            size *= 2;
            str = (char*)realloc(str, size * sizeof(char));
            if(str == NULL) {
                printf("Memory reallocation failed!\n");
                exit(1);
            }
        }
        str[(*len)++] = (char)ch;
    }
    str[*len] = '\0';
    return str;
}

int isRotation(char *str1, char *str2,int *len1,int *len2) {

    if(*len1 != *len2) {
        return 0;
    }

    char *temp = (char*)malloc((2*(*len1) + 1) * sizeof(char));
    if(temp == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }
    strcpy(temp, str1);
    strcat(temp, str1);

    int result = (strstr(temp, str2) != NULL);

    free(temp);
    return result;
}

int main() {
    int len1 = 0;
    char *str1 = getString(&len1);
    int len2 = 0;
    char *str2 = getString(&len2);

    if(isRotation(str1, str2, &len1, &len2)) {
        printf("'%s' is a rotation of '%s'\n", str2, str1);
    } else {
        printf("'%s' is NOT a rotation of '%s'\n", str2, str1);
    }
    free(str1);
    free(str2);
    return 0;
}
