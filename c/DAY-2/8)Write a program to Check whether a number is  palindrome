#include <stdio.h>
void main(){
    int rev=0;
    unsigned int num, t;
    printf("Enter a number: ");
    scanf("%u", &num);
    t=num;

    while(t!=0){
        rev=rev*10+t%10;
        t=t/10;
    }

    if(rev==num){
        printf("%u is a palindrome number.", num);
    }
    else{
        printf("%u is not a palindrome number.", num);
    }
}