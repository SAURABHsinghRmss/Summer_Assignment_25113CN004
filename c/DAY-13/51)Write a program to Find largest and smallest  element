#include <stdio.h>
#include <stdlib.h>
int* INarray(int s){
    int *arr=(int*)malloc(s*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",s);
    for(int i=0 ;i<s ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}
void LARsmall(int* ptr , int s){
    unsigned long int lar, small;
    lar= *ptr;
    small= *ptr;
    printf("REQUIRED output : \n");
    for(int i=1 ;i<s ;i++){
        if((*(ptr+i))>lar){
            lar=(*(ptr+i));
        }
        if((*(ptr+i))<small){
            small=(*(ptr+i));
        }
    }
    printf("Largest element = %lu \n",lar);
    printf("smallest element = %lu \n",small);
}

int main(){
    int n;
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n);
    if(n<=1){
        printf("Invalid size. \n");
        return 1;
    }

    int *ptr = INarray(n);

    LARsmall(ptr , n);

    return 0;
}