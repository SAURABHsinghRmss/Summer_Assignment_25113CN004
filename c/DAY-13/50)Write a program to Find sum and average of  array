#include <stdio.h>
#include <stdlib.h>
int* INarray(int s){
    int *arr=(int*)malloc(s*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",s);
    for(int i=0 ;i<s ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}
void SUMavera(int* ptr , int s){
    unsigned long long sum=0;
    unsigned long int average;
    printf("You entered : \n");
    for(int i=0 ;i<s ;i++){
        sum=sum + (*(ptr+i));
    }
    average=sum/s;
    printf("Sum = %llu \n",sum);
    printf("Average = %lu \n",average);
}

int main(){
    int n;
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n);
    if(n<=1){
        printf("Invalid size. \n");
        return 1;
    }

    int *ptr = INarray(n);

    SUNavera(ptr , n);

    return 0;
}