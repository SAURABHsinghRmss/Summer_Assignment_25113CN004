#include <stdio.h>
#include <stdlib.h>
int* INarray(int s){
    int *arr=(int*)malloc(s*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",s);
    for(int i=0 ;i<s ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}
void EVENodd(int* ptr , int s){
    unsigned long int even, odd;
    printf("REQUIRED output : \n");
    for(int i=1 ;i<s ;i++){
        if((*(ptr+i))%2==0){
            even++;
        }
        if((*(ptr+i))%2!=0){
            odd++;
        }
    }
    printf("Number of even element = %lu \n",even);
    printf("Number of odd element = %lu \n",odd);
}

int main(){
    int n;
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n);
    if(n<=1){
        printf("Invalid size. \n");
        return 1;
    }

    int *ptr = INarray(n);

    EVENodd(ptr , n);

    return 0;
}