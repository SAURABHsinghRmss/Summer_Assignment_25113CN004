#include <stdio.h>
#include <stdlib.h>
int* INarray(int s){
    int *arr=(int*)malloc(s*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",s);
    for(int i=0 ;i<s ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}

int* SelectionSort(int* ptr , int s){
    for(int i=0 ;i<s-1 ;i++){
        int x = i;
        for(int j=i+1 ;j<s ;j++){
            if(*(ptr+j)<*(ptr+x)){
                x = j;
            }
        }
        if(x!=i){
            int t = *(ptr+i);
            *(ptr+i) = *(ptr+x);
            *(ptr+x) = t;
        }
    }
    return 0;
}

void OUTarray(int* ptr , int s){
    printf("The sorted array is : \n");
    for(int i=0 ;i<s ;i++){
        printf("%d \n", *(ptr+i));
    }
}

int binarySearch(int* ptr, int s){
    int ele;
    printf("Enter the element to search = ");
    if(scanf("%d",&ele)!=1){
        printf("Invalid input. \n");
        return 1;
    }
    int beg=0 , end=(s-1) , mid=(beg+end)/2;
    while(beg<=end && *(ptr+mid)!=ele){
        if(*(ptr+mid)<ele){
            beg = mid + 1;
        }
        else{
            end = mid - 1;
        }
        mid = (beg+end)/2;
    }
    if(ele==*(ptr+mid)){
        printf("Element %d is found at index %d. \n",ele,mid);
    }
    else{
        printf("Element %d is not found in the array. \n",ele);

    }
    return 0;
}

int main(){
    int n;
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n);
    if(n<=1){
        printf("Invalid size. \n");
        return 1;
    }

    int *ptr = INarray(n);

    printf("CHOICES : \n 1) Sort the array. \n 2) Inputed array is already sorted. \n");
    int choice;
    printf("Enter your choice = ");
    scanf("%d",&choice);
    
    switch(choice){
        case 1:
            SelectionSort(ptr , n);
            OUTarray(ptr , n);
            printf("-------------------------------------------------------------------------------------------\n");
            binarySearch(ptr , n);
            break;
        case 2:
            printf("-------------------------------------------------------------------------------------------\n");
            binarySearch(ptr , n);
            break;
        default:
            printf("Invalid choice. \n");
            free(ptr);
            return 1;
    }

    free(ptr);
    return 0;
}