#include <stdio.h>
#include <stdlib.h>

int* INarray(int n) {
    int *arr = (int*)malloc(n * sizeof(int));
    if(arr == NULL) {
        printf("Memory allocation failed\n");
        exit(1);
    }
    printf("Enter %d integers:\n", n);
    for(int i = 0; i < n; i++) {
        printf("Element %d = ", i+1);
        scanf("%d", &arr[i]);
    }
    return arr;
}

void insertionSortDesc(int* arr, int n) {
    for(int i = 1; i < n; i++) {
        int key = arr[i];
        int j = i - 1;

        while(j >= 0 && arr[j] < key) {
            arr[j+1] = arr[j];
            j--;
        }
        arr[j+1] = key;
    }
}

void OUTarray(int* arr, int n) {
    printf("Array after sorting in descending order:\n");
    for(int i = 0; i < n; i++) {
        printf("%d\n", arr[i]);
    }
}

int main() {
    int n;
    printf("Enter number of elements in array = ");
    scanf("%d", &n);
    if(n <= 1) {
        printf("Invalid size.\n");
        return 1;
    }

    int *arr = INarray(n);
    insertionSortDesc(arr, n);
    OUTarray(arr, n);

    free(arr);
    return 0;
}
