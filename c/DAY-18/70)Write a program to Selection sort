#include <stdio.h>
#include <stdlib.h>
int* INarray(int s){
    int *arr=(int*)malloc(s*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",s);
    for(int i=0 ;i<s ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}

int* SelectionSort(int* ptr , int s){
    for(int i=0 ;i<s-1 ;i++){
        int x = i;
        for(int j=i+1 ;j<s ;j++){
            if(*(ptr+j)<*(ptr+x)){
                x = j;
            }
        }
        if(x!=i){
            int t = *(ptr+i);
            *(ptr+i) = *(ptr+x);
            *(ptr+x) = t;
        }
    }
    return 0;
}

void OUTarray(int* ptr , int s){
    printf("You entered : \n");
    for(int i=0 ;i<s ;i++){
        printf("%d \n", *(ptr+i));
    }
}

int main(){
    int n;
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n);
    if(n<=1){
        printf("Invalid size. \n");
        return 1;
    }

    int *ptr = INarray(n);
    SelectionSort(ptr , n);
    printf("Array after sorted through Selection Sorting \n");
    OUTarray(ptr , n);

    free(ptr);
    return 0;
}