#include <stdio.h>
#include <stdlib.h>
int* INarray(int s){
    int *arr=(int*)malloc(s*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",s);
    for(int i=0 ;i<s ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}

int* BubbleSort(int* ptr , int s){
    for(int i=0 ;i<s-1 ;i++){
        for(int j=0 ;j<s-i-1 ;j++){
            if(*(ptr+j) > *(ptr+j+1)){
                int t = *(ptr+j);
                *(ptr+j) = *(ptr+j+1);
                *(ptr+j+1) = t;
            }
        }
    }
    return 0;
}

void OUTarray(int* ptr , int s){
    printf("You entered : \n");
    for(int i=0 ;i<s ;i++){
        printf("%d \n", *(ptr+i));
    }
}

int main(){
    int n;
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n);
    if(n<=1){
        printf("Invalid size. \n");
        return 1;
    }

    int *ptr = INarray(n);
    BubbleSort(ptr , n);
    printf("Array after sorted through Bubble Sorting \n");
    OUTarray(ptr , n);

    free(ptr);
    return 0;
}