#include <stdio.h>
#include <stdlib.h>
int* INarray(int n){
    int *arr=(int*)malloc(n*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",n);
    for(int i=0 ;i<n ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}

int* commonARR(int* ptr1, int* ptr2, int s1, int s2, int *s) {
    int *arr = (int*)malloc((*s) * sizeof(int));
    if(arr == NULL) {
        printf("Memory allocation failed\n");
        exit(1);
    }

    int k = 0;
    for(int i = 0; i < s1; i++) {
        for(int j = 0; j < s2; j++) {
            if(ptr1[i] == ptr2[j]) {
                arr[k++] = ptr1[i];  
                // Use "break" to avoid adding duplicates if the same element appears multiple times in ptr2
                // I didn't add a break here because we want to find all common elements, including duplicates.
            }
        }
    }

    *s = k;
    return arr;
}


void showARR(int* ptr , int s){
    for(int i=0 ; i<s ; i++){
        printf("%d \n", *(ptr+i));
    }
}

int main(){
    int n1 , n2 ;
    printf("For first array : \n");
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n1);
    if(n1<=1){
        printf("Invalid size. \n");
        return 0;
    }
    int *ptr1 = INarray(n1);
    printf("For second array : \n");
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n2);
    if(n2<=1){
        printf("Invalid size. \n");
        return 0;
    }
    int *ptr2 = INarray(n2);
    
    int n= n1 + n2 ;

    printf("Common elements of two arrays : \n");
    int *p = &n;
    int *Uptr = commonARR(ptr1, ptr2, n1,n2,p);
            
    showARR(Uptr , *p);
    free(Uptr);
    free(ptr1);
    free(ptr2);
    return 0;
}