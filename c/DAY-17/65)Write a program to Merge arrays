#include <stdio.h>
#include <stdlib.h>
int* INarray(int n){
    int *arr=(int*)malloc(n*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",n);
    for(int i=0 ;i<n ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}

int* SmergeARR(int* ptr1 , int* ptr2, int s1,int s2){
    int s= s1 + s2 ;
    int *arr=(int*)malloc(s*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    int j=0, k=0;
    for(int i =  0 ; i < s ; i++){
        if(j < s1){
            arr[i] = ptr1[j++];
        }
        else{
            arr[i] = ptr2[k++];
        }
    }
    return arr;
}

int* UmergeARR(int* ptr1, int* ptr2, int s1, int s2, int *s) {
    int *arr = (int*)malloc((s1+s2) * sizeof(int));
    if(arr == NULL) {
        printf("Memory allocation failed\n");
        exit(1);
    }

    int i = 0;

    for(int j = 0; j < s1; j++) {
        int exists = 0;
        for(int k = 0; k < i; k++) {
            if(arr[k] == ptr1[j]) {
                exists = 1;
                break;
            }
        }
        if(!exists){
             arr[i++] = ptr1[j];
        }
    }

    for(int j = 0; j < s2; j++) {
        int exists = 0;
        for(int k = 0; k < i; k++) {
            if(arr[k] == ptr2[j]) {
                exists = 1;
                break;
            }
        }
        if(!exists){
            arr[i++] = ptr2[j];
        } 
    }

    *s = i;
    return arr;
}


void showARR(int* ptr , int s){
    for(int i=0 ; i<s ; i++){
        printf("%d \n", *(ptr+i));
    }
}

int main(){
    int n1 , n2 ;
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n1);
    if(n1<=1){
        printf("Invalid size. \n");
        return 0;
    }
    int *ptr1 = INarray(n1);
    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n2);
    if(n2<=1){
        printf("Invalid size. \n");
        return 0;
    }
    int *ptr2 = INarray(n2);
    int n = n1 + n2 ;
    printf("choices : \n1)Simple Merge two arrays \n2)Unique Merge two array \n");
    printf("Enter your choice = ");
    int choice ;
    scanf("%d",&choice);
    switch(choice){
        case 1 : 
            printf("Simple Merge of two arrays : \n");
            int *Sptr = SmergeARR(ptr1, ptr2, n1,n2);
            showARR(Sptr , n);
            free(Sptr);
            break;
        case 2 :
            printf("Unique Merge of two arrays : \n");
            int *p = &n;
            int *Uptr = UmergeARR(ptr1, ptr2, n1,n2,p);
            
            showARR(Uptr , *p);
            free(Uptr);
            break;
        default :
            printf("Invalid choice. \n");
    }
    free(ptr1);
    free(ptr2);
    return 0;
}