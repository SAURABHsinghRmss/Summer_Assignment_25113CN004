#include <stdio.h>
#include <stdlib.h>
int* INarray(int n){
    int *arr=(int*)malloc(n*sizeof(int));
    if(arr==NULL){
        printf("Memory allocation failed \n");
        exit(1);
    }
    printf("Enter %d integer : \n",n);
    for(int i=0 ;i<n ;i++){
        printf("Element %d = ",i+1);
        if(scanf("%d",&arr[i])!=1){
            printf("Invalid input. \n");
            free(arr);
            exit(1);
        }
    }
    return arr;
}

int* UnionARR(int* ptr1, int* ptr2, int s1, int s2, int *s) {
    int *arr = (int*)malloc((s1+s2) * sizeof(int));
    if(arr == NULL) {
        printf("Memory allocation failed\n");
        exit(1);
    }

    int i = 0;

    for(int j = 0; j < s1; j++) {
        int exists = 0;
        for(int k = 0; k < i; k++) {
            if(arr[k] == ptr1[j]) {
                exists = 1;
                break;
            }
        }
        if(!exists){
            arr[i++] = ptr1[j];
        }
    }

    for(int j = 0; j < s2; j++) {
        int exists = 0;
        for(int k = 0; k < i; k++) {
            if(arr[k] == ptr2[j]) {
                exists = 1;
                break;
            }
        }
        if(!exists){
            arr[i++] = ptr2[j];
        } 
    }

    *s = i;

    for(int x = 0; x < *s - 1; x++) {
        for(int y = 0; y < *s - x - 1; y++) {
            if(arr[y] > arr[y+1]) {
                int temp = arr[y];
                arr[y] = arr[y+1];
                arr[y+1] = temp;
            }
        }
    }

    return arr;
}

void showARR(int* ptr , int s){
    for(int i=0 ; i<s ; i++){
        printf("%d \n", *(ptr+i));
    }
}

int main(){
    int n1 , n2 ;

    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n1);
    if(n1<=1){
        printf("Invalid size. \n");
        return 0;
    }
    int *ptr1 = INarray(n1);

    printf("Enter number of elements to enter in an array = ");
    scanf("%d",&n2);
    if(n2<=1){
        printf("Invalid size. \n");
        return 0;
    }
    int *ptr2 = INarray(n2);
    
    int n = n1 + n2 ;
    printf("Union of two arrays : \n");
    int *p = &n;
    int *Uptr = UnionARR(ptr1, ptr2, n1,n2,p);
            
    showARR(Uptr , *p);
    free(Uptr);
    free(ptr1);
    free(ptr2);
    return 0;
}