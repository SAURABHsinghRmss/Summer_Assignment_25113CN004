#include <stdio.h>
#include <stdlib.h>
#include <string.h>
char* getString() {
    int size = 10;
    int len = 0;
    char *str = (char*)malloc(size * sizeof(char));
    if(str == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }

    int ch;
    while((ch = getchar()) != '\n' && ch != EOF) {
        if(len >= size - 1) {
            size *= 2;
            str = (char*)realloc(str, size * sizeof(char));
            if(str == NULL) {
                printf("Memory reallocation failed!\n");
                exit(1);
            }
        }
        str[len++] = (char)ch;
    }
    str[len] = '\0';
    return str;
}

void RevSTRING(char *str , int len){
    printf("REVERSE of a string : \n");
    for(int i=len-1 ; i>=0 ; i--){
        printf("%c",str[i]);
    }
    printf("\n");
}

int main() {
    printf("Enter a string: ");
    char *str = getString();

    int len = strlen(str);

    RevSTRING(str,len);

    free(str);
    return 0;
}