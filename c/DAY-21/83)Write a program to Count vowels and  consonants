#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
char* getString() {
    int size = 10;
    int len = 0;
    char *str = (char*)malloc(size * sizeof(char));
    if(str == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }

    int ch;
    while((ch = getchar()) != '\n' && ch != EOF) {
        if(len >= size - 1) {
            size *= 2;
            str = (char*)realloc(str, size * sizeof(char));
            if(str == NULL) {
                printf("Memory reallocation failed!\n");
                exit(1);
            }
        }
        str[len++] = (char)ch;
    }
    str[len] = '\0';
    return str;
}

void vowconsonantcount(char *str){
    int vow=0 , consonant=0 ;
    for(int i = 0; str[i] != '\0'; i++) {
        char ch = tolower(str[i]); 
        if(ch >= 'a' && ch <= 'z') {  
            if(ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u')
                vow++;
            else
                consonant++;
        }
    }
    printf("Vowels in inputed string = %d \n",vow);
    printf("Consonant in inputed string = %d \n",consonant);
}

int main() {
    printf("Enter a string: ");
    char *str = getString();

    vowconsonantcount(str);

    free(str);
    return 0;
}