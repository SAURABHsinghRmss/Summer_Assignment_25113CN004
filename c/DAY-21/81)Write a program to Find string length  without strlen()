#include <stdio.h>
#include <stdlib.h>

char* getString() {
    int size = 10;
    int len = 0;
    char *str = (char*)malloc(size * sizeof(char));
    if(str == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }

    int ch;
    while((ch = getchar()) != '\n' && ch != EOF) {
        if(len >= size - 1) {
            size *= 2;
            str = (char*)realloc(str, size * sizeof(char));
            if(str == NULL) {
                printf("Memory reallocation failed!\n");
                exit(1);
            }
        }
        str[len++] = (char)ch;
    }
    str[len] = '\0';
    return str;
}

int strLen(char *str) {
    int x = 0;
    while(str[x] != '\0') {
        x++;
    }
    return x;
}

int main() {
    printf("Enter a string: ");
    char *str = getString();

    int len = strLen(str);
    printf("Length of string = %d\n", len);

    free(str);
    return 0;
}