#include <stdio.h>
#include <math.h>
int main(void) {
    char str[150], t;
    double a, b;
    int j=0;
    printf("Enter binary number = ");
    if (scanf("%149s", str) != 1) {
        printf("Invalid Input!!!\n");
        return 1;
    }
    unsigned int i = 0;
    while (str[i] != '\0') {
        printf("Character at index %u: %c\n", i, str[i]);
        t=str[i];
        if((t!='1')&&(t!='.')&&(t!='0')){
            printf("Invalid Input!!!\n");
            return 1;
        }
        if(t=='.'){
            j=i-1;
        }
        i++;
    }
    i=0;
    while(str[i] != '\0'){
        b=pow(2,j--);
        if(str[i]=='1'){
            a+=b;
        }
        else if(str[i]=='.'){
            j++;
        }
        i++;
    }
    printf("%lf",a);
    return 0;
}