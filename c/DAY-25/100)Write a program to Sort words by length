#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char** getWords(int count) {
    char **words = (char**)malloc(count * sizeof(char*));
    if(words == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }
    getchar();

    for(int j = 0; j < count; j++) {
        printf("%d) ", j+1);
        int size = 10;
        int len = 0;
        words[j] = (char*)malloc(size * sizeof(char));
        if(words[j] == NULL) {
            printf("Memory allocation failed!\n");
            exit(1);
        }

        int ch;
        while((ch = getchar()) != '\n' && ch != EOF) {
            if(len >= size - 1) {
                size *= 2;
                words[j] = (char*)realloc(words[j], size * sizeof(char));
                if(words[j] == NULL) {
                    printf("Memory reallocation failed!\n");
                    exit(1);
                }
            }
            words[j][len++] = (char)ch;
        }
        words[j][len] = '\0'; 
    }
    return words;
}

void sortWordsByLength(char **words, int n) {
    for(int i = 0; i < n-1; i++) {
        for(int j = i+1; j < n; j++) {
            int len1 = strlen(words[i]);
            int len2 = strlen(words[j]);

            if(len1 > len2 || (len1 == len2 && strcmp(words[i], words[j]) > 0)) {
                char temp[100];
                strcpy(temp, words[i]);
                strcpy(words[i], words[j]);
                strcpy(words[j], temp);
            }
        }
    }
}

void showWords(char **words, int n) {
    printf("\nWords sorted by length:\n");
    for(int i = 0; i < n; i++) {
        printf("%d: %s\n", i+1, words[i]);
    }
}

int main() {
    int n;
    printf("Number of words: ");
    scanf("%d", &n);

    char **words = getWords(n);

    sortWordsByLength(words, n);

    showWords(words, n);

    for(int i = 0; i < n; i++) {
        free(words[i]);
    }
    free(words);

    return 0;
}