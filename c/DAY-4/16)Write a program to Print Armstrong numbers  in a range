#include <stdio.h>
#include <math.h>
unsigned int digits(unsigned int n){
    unsigned int count = 0;
    while(n > 0){
        count++;
        n /= 10;
    }
    return count;
}
void main(){
    unsigned int n, temp, r, d;
    unsigned long long sum = 0;
    printf("Enter a number: ");
    scanf("%u", &n);

    printf("Armstrong numbers in the range 1 to %u are:\n", n);

    for(unsigned int i = 1; i <= n; i++){
        sum = 0;
        temp = i;
        d = digits(i);
        while(temp > 0){
            r = temp%10;
            sum += pow(r, d);
            temp /= 10;
        }
        if(sum == i){
            printf("%u\n", i);
        }
    }
}
