#include <stdio.h>
#include <math.h>
unsigned int digits(unsigned int n){
    unsigned int count = 0;
    while(n > 0){
        count++;
        n /= 10;
    }
    return count;
}
void main(){
    unsigned int n, temp, r, d;
    unsigned long long sum = 0;
    printf("Enter a number: ");
    scanf("%u", &n);
    temp = n;
    d = digits(n);
    while(temp > 0){
        r = temp%10;
        sum += pow(r, d);
        temp /= 10;
    }
    if(sum == n){
        printf("%u is an Armstrong number.\n", n);
    } else {
        printf("%u is not an Armstrong number.\n", n);
    }
}