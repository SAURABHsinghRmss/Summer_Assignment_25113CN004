#include <stdio.h>
#include <math.h>
unsigned int digits(unsigned int n){
    unsigned int count = 0;
    while(n > 0){
        count++;
        n /= 10;
    }
    return count;
}

unsigned long long power(unsigned int r, unsigned int d){
    unsigned int d1=d;
    while( d1 !=0){
        r=r*d;
        d1-=1;
    }
    return r;
}

unsigned long long armstrong(unsigned int n){
    unsigned int temp,r,d;
    unsigned long long sum = 0;
    temp = n;
    d = digits(n);
    while(temp > 0){
        r = temp%10;
        sum += power(r, d);
        temp /= 10;
    }
    if(sum == n){
        printf("%u is an Armstrong number.\n", n);
    } else {
        printf("%u is not an Armstrong number.\n", n);
    }
}

void main(){
    unsigned int n;
    printf("Enter a number: ");
    scanf("%u", &n);
    armstrong(n);
}