#include <stdio.h>
int main(){
    int h,a,i,j;
    printf("Enter the height of the square: ");
    scanf("%d",&h);
    for( i=1;i<=h;i++){
        for( j=1;j<=h;j++){
            if((i==1)||(i==h)||(j==1)||(j==h)){
                printf("*");
            }
            else{
                printf(" ");
            }
        }
        printf("\n");
    }
    return 0;
}