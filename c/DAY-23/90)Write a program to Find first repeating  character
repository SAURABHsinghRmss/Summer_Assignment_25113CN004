#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

char* getString() {
    int size = 10, len = 0;
    char *str = (char*)malloc(size * sizeof(char));
    if(str == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }

    int ch;
    while((ch = getchar()) != '\n' && ch != EOF) {
        if(len >= size - 1) {
            size *= 2;
            str = (char*)realloc(str, size * sizeof(char));
            if(str == NULL) {
                printf("Memory reallocation failed!\n");
                exit(1);
            }
        }
        str[len++] = (char)ch;
    }
    str[len] = '\0';
    return str;
}

void firstRepeatingIgnoreCase(char *str) {
    int freq[256] = {0};  // frequency array for ASCII

    for(int i = 0; str[i] != '\0'; i++) {
        char ch = tolower((unsigned char)str[i]);  
        freq[ch]++;
        if(freq[ch] == 2) {  
            printf("First repeating character (case-insensitive): '%c'\n", str[i]);
            return;
        }
    }

    printf("No repeating character found.\n");
}

int main() {
    printf("Enter a string: ");
    char *str = getString();

    firstRepeatingIgnoreCase(str);

    free(str);
    return 0;
}
