#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

char* getString(int *len) {
    printf("Enter a string: ");
    int size = 10;
    *len = 0; 
    char *str = (char*)malloc(size * sizeof(char));
    if(str == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }

    int ch;
    while((ch = getchar()) != '\n' && ch != EOF) {
        if(*len >= size - 1) {
            size *= 2;
            str = (char*)realloc(str, size * sizeof(char));
            if(str == NULL) {
                printf("Memory reallocation failed!\n");
                exit(1);
            }
        }
        str[(*len)++] = (char)ch;
    }
    str[*len] = '\0';
    return str;
}

void maxfreqCHAR(char *str, int len) {
    int freq[256] = {0};

    for(int i = 0; i < len; i++) {
        freq[(unsigned char)tolower(str[i])]++;
    }

    int max = 0;
    char maxChar = '\0';
    for(int i = 0; i < 256; i++) {
        if(freq[i] > max) {
            max = freq[i];
            maxChar = (char)i;
        }
    }

    if(maxChar != '\0')
        printf("Character with max frequency: '%c' (appears %d times)\n", maxChar, max);
    else
        printf("No characters found.\n");
}

int main() {
    int len = 0;
    char *str = getString(&len);

    maxfreqCHAR(str, len);

    free(str);
    return 0;
}
