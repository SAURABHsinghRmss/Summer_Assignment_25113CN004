#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

char* getString(int *len) {
    printf("Enter a string: ");
    int size = 10;
    *len = 0;  // initialize length
    char *str = (char*)malloc(size * sizeof(char));
    if(str == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }

    int ch;
    while((ch = getchar()) != '\n' && ch != EOF) {
        if(*len >= size - 1) {
            size *= 2;
            str = (char*)realloc(str, size * sizeof(char));
            if(str == NULL) {
                printf("Memory reallocation failed!\n");
                exit(1);
            }
        }
        str[(*len)++] = (char)ch;
    }
    str[*len] = '\0';
    return str;
}

void anagramstr(char *str1, char *str2, int len) {
    int freq1[256] = {0};
    int freq2[256] = {0};

    for(int i = 0; i < len; i++) {
        freq1[(unsigned char)tolower(str1[i])]++;
        freq2[(unsigned char)tolower(str2[i])]++;
    }

    for(int i = 0; i < 256; i++) {
        if(freq1[i] != freq2[i]) {
            printf("Strings are NOT anagrams.\n");
            return;
        }
    }
    printf("Strings are anagrams!\n");
}

int main() {
    int len1 = 0, len2 = 0;
    char *str1 = getString(&len1);
    char *str2 = getString(&len2);

    if(len1 != len2) {
        printf("Strings are NOT anagrams.\n");
    } else {
        anagramstr(str1, str2, len1);
    }

    free(str1);
    free(str2);
    return 0;
}